# LOGS_DB_LOCAL_PORT=27017

# -----------------------------
# CLIENT
# -----------------------------
CLIENT_LOCAL_PORT=#PORT

# API de Front
VITE_API_URL=http://localhost:#PORT
VITE_API_BASE_PATH=/api

