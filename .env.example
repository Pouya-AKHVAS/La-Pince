# .env.docker.example = versionné
# .env.docker         = non versionné

# Ce fichier regroupe les variables d'environnement à fournir au docker-compose pour le lancement des différents services

# Local : 
#        docker compose --env-file=.env.docker.example
# (ou)   docker compose --env-file=.env.docker

# Prod :  
#        docker compose --env-file=.env.docker


# -----------------------------
# DATABASE
# -----------------------------
POSTGRES_USER=# DEFINIR VOTRE USERNAME
POSTGRES_PASSWORD=# DEFINIR VOTRE PASSWORD
POSTGRES_DB=# DEFINIR LE NOM DE VOTRE DATABASE
POSTGRES_LOCAL_PORT=# DEFINIR LE PORT



# -----------------------------
# API
# -----------------------------

NODE_ENV=development

JWT_SECRET=# METTRE UN MOT DE PASSE

NODE_ENV=development

# Remarque : Le nom du service de base de données dans :  docker-compose  = db
DATABASE_URL= postgres://##USERNAME:PASSWORD@database:PORT/DATABASENAME

API_PORT=#PORT
API_LOCAL_PORT=#PORT

#  CORS
CORS_ORIGIN=http://localhost:#PORT

# # ALLOWED_ORIGINS=oquiz.PSEUDO-server.eddi.cloud
# LOG_LEVEL=http

