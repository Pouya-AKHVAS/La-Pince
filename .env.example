# .env.docker.example = versionné
# .env.docker         = non versionné

# Ce fichier regroupe les variables d'environnement à fournir au docker-compose pour le lancement des différents services

# Local :
#        docker compose --env-file=.env.docker.example
# (ou)   docker compose --env-file=.env.docker

# Prod :
#        docker compose --env-file=.env.docker


# -----------------------------
# DATABASE
# -----------------------------

# Nom d'utilisateur PostgreSQL
POSTGRES_USER=votre_username

# CONFIDENTIEL — mot de passe de la base de données
POSTGRES_PASSWORD=votre_password

# Nom de la base de données
POSTGRES_DB=votre_database

# Port local exposé pour PostgreSQL
POSTGRES_LOCAL_PORT=5454


# -----------------------------
# API
# -----------------------------

# Environnement Node
NODE_ENV=development

# CONFIDENTIEL — clé secrète pour signer les tokens JWT (chaîne longue et aléatoire)
JWT_SECRET=votre_jwt_secret_long_et_aleatoire

# Remarque : Le nom du service de base de données dans docker-compose = db
# CONFIDENTIEL — contient le mot de passe de la base de données
DATABASE_URL=postgres://votre_username:votre_password@db:5432/votre_database

# Port interne et externe de l'API
API_PORT=3007
API_LOCAL_PORT=3007

# Origine autorisée pour les requêtes CORS
CORS_ORIGIN=http://localhost:8080


# -----------------------------
# CLIENT
# -----------------------------

# Port local exposé pour le client
CLIENT_LOCAL_PORT=8080

# URL de base de l'API appelée par le frontend (relatif = proxy nginx en Docker)
VITE_API_BASE_URL=/api
