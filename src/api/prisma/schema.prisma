generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CategoryType {
  EXPENSE
  INCOME
}

model User {
  id         Int     @id @default(autoincrement())
  first_name String
  last_name  String
  email      String  @unique
  password   String
  photo      String?

  // Relations
  budgets       Budget[]
  alerts        Alert[]
  transactions  Transaction[]
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
  expiresAt DateTime

  @@map("refresh_tokens")
}

model Category {
  id    Int          @id @default(autoincrement())
  name  String
  color String?
  icon  String?
  type  CategoryType

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  /// Relation avec les transactions
  transactions Transaction[]
  budgets      Budget[]

  @@unique([name])
  @@map("category")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  amount      Decimal
  date        DateTime
  description String?

  // Clés étrangères
  userId     Int @map("iduser") // Mappé pour garder le nom en BDD
  categoryId Int @map("idcategory") // Mappé pour garder le nom en BDD

  // Relations
  category Category @relation(fields: [categoryId], references: [id])
  User     User     @relation(fields: [userId], references: [id])
  budget   Budget?  @relation(fields: [budgetId], references: [id])
  budgetId Int?

  @@map("transactions")
}

model Budget {
  id           Int    @id @default(autoincrement())
  limit_amount Float
  period       String
  id_category  Int
  userId       Int

  // Relation avec l'utilisateur (un budget appartient à un utilisateur)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relation avec la catégorie (un budget concerne une catégorie)
  category Category @relation(fields: [id_category], references: [id])

  // Relation avec les transactions (un budget peut avoir plusieurs transactions)
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  @@map("budgets")
}

model Alert {
  id             Int      @id @default(autoincrement())
  categoryName   String
  exceededAmount Float
  isRead         Boolean  @default(false)
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@map("alerts")
}
