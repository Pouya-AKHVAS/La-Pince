//Prisma Client est toujours installé dans le répertoire standard : node_modules/@prisma/client

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  
  
}

enum CategoryType {
  EXPENSE
  INCOME
}

model User {
  id        Int      @id @default(autoincrement())
  first_name String
  last_name String
  email     String   @unique
  password  String
  photo     String?
 
  createdAt DateTime @default(now())
  updatedAt  DateTime @updatedAt()
  refreshTokens RefreshToken[]

 /// Relation avec les transactions
  transactions Transaction[]


  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
  expiresAt DateTime

  @@map("refresh_tokens")

  
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  color       String?
  icon        String?
  type        CategoryType



  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt


    /// Relation avec les transactions
      transactions Transaction[]


  @@unique([name])
  @@map("category")


}


model Transaction {
  id          Int      @id @default(autoincrement())
  amount      Decimal  
  date        DateTime
  description String?
  
  // Clés étrangères
  userId      Int      @map("iduser")     // Mappé pour garder le nom en BDD
  categoryId  Int      @map("idcategory") // Mappé pour garder le nom en BDD
  
  // Relations
  category  Category @relation(fields: [categoryId], references: [id]) // Relation avec Category, en mappant categoryId à idcategory en BDD
   User     User     @relation(fields: [userId], references: [id]) // Relation avec User, en mappant userId à iduser en BDD

  @@map("transactions")
}