generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

enum CategoryType {
  EXPENSE
  INCOME
}

model User {
  id        Int      @id @default(autoincrement())
  first_name String
  last_name String
  email     String   @unique
  password  String
  photo     String?
  categories Category[]
  createdAt DateTime @default(now())
  updatedAt  DateTime @updatedAt()
  refreshTokens RefreshToken[]

 

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
  expiresAt DateTime

  @@map("refresh_tokens")
}


model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  color       String?
  icon        String?
  type        CategoryType
  is_default  Boolean  @default(false)
  id_user     Int?
  user        User?    @relation(fields: [id_user], references: [id])
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

    @@unique ([name, id_user])
  @@map("category")
}