@baseUrl = http://localhost:3007

### 1. Inscription valide
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "first_name": "Alice",
  "last_name": "Dupont",
  "email": "alice@example.com",
  "password": "motdepasse123",
  "photo": "url"
}

### 2. Email déjà utilisé → 409
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "first_name": "Alice",
  "last_name": "Dupont",
  "email": "alice@example.com",
  "password": "motdepasse123"
}

### 3. Email invalide → 400
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "first_name": "Bob",
  "last_name": "Martin",
  "email": "pas-un-email",
  "password": "motdepasse123"
}

### 4. Mot de passe trop court → 400
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "first_name": "Bob",
  "last_name": "Martin",
  "email": "bob@example.com",
  "password": "court"
}

### 5. Champs manquants → 400
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "incomplet@example.com",
  "password": "motdepasse123"
}
